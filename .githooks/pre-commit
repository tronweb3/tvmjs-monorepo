#!/usr/bin/env bash

node ./node_modules/lint-staged/bin/lint-staged.js

#
# Git Pre-Commit Hook: Claude Code Security & Quality Review
# Blocking mode: commit is rejected if CRITICAL or HIGH issues are found.
#

set -euo pipefail

# ============== Configuration ==============
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
REPORT_DIR="${PROJECT_ROOT}/.claude/review-reports"
TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
SECURITY_REPORT="${REPORT_DIR}/security-review-${TIMESTAMP}.md"
QUALITY_REPORT="${REPORT_DIR}/quality-review-${TIMESTAMP}.md"

# Blocking thresholds (exit 1 if any CRITICAL or HIGH found)
BLOCK_ON_CRITICAL=true
BLOCK_ON_HIGH=true

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ============== Pre-checks ==============
# Resolve claude command: prefer global, fall back to local node_modules, then npx
if command -v claude &>/dev/null; then
    CLAUDE_CMD=(claude)
elif [ -x "${PROJECT_ROOT}/node_modules/.bin/claude" ]; then
    CLAUDE_CMD=("${PROJECT_ROOT}/node_modules/.bin/claude")
elif command -v npx &>/dev/null && npx --no-install claude --version &>/dev/null 2>&1; then
    CLAUDE_CMD=(npx claude)
else
    echo -e "${RED}[pre-commit] claude CLI not found. Skipping security review.${NC}"
    echo -e "${YELLOW}Install globally: npm install -g @anthropic-ai/claude-code${NC}"
    echo -e "${YELLOW}Or locally:       npm install @anthropic-ai/claude-code${NC}"
    exit 0
fi

# Get staged TypeScript/JavaScript/config files only
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|js|tsx|jsx|mjs|cjs|json)$' | grep -v 'node_modules' || true)

if [ -z "${STAGED_FILES}" ]; then
    echo -e "${GREEN}[pre-commit] No TypeScript/JavaScript files staged. Skipping review.${NC}"
    exit 0
fi

FILE_COUNT=$(echo "${STAGED_FILES}" | wc -l | tr -d ' ')
echo -e "${CYAN}${BOLD}======================================================${NC}"
echo -e "${CYAN}${BOLD}  Claude Code Pre-Commit Security & Quality Review${NC}"
echo -e "${CYAN}${BOLD}======================================================${NC}"
echo -e "${CYAN}[pre-commit] Scanning ${FILE_COUNT} staged file(s)...${NC}"
echo ""

# Create report directory
mkdir -p "${REPORT_DIR}"

# Build file list for the prompt
FILE_LIST=$(echo "${STAGED_FILES}" | sed 's/^/- /')

# Generate diff of staged changes for review context
STAGED_DIFF=$(git diff --cached -- ${STAGED_FILES})

# ============== Skill 1: Security Review ==============
echo -e "${YELLOW}[1/2] Running security vulnerability scan...${NC}"

SECURITY_PROMPT="$(cat <<EOF
You are a senior TypeScript/JavaScript security engineer performing a pre-commit security review for the TVMJS project.

## Staged Files:
${FILE_LIST}

## Staged Diff:
\`\`\`diff
${STAGED_DIFF}
\`\`\`

Review ONLY the staged changes above. Focus on:
1. Private key / mnemonic / seed exposure — logging, returning, or leaking cryptographic secrets
2. Insecure cryptography — weak algorithms, improper key derivation, predictable randomness
3. Injection vulnerabilities — eval(), Function(), dynamic code execution with user input
4. Prototype pollution — unsafe Object.assign / merge with untrusted input
5. SSRF / open redirect — outbound HTTP calls without URL validation
6. Hardcoded secrets — API keys, private keys, passwords, RPC endpoints with credentials
7. Input validation gaps — missing address/hex/amount validation before on-chain calls
8. Dependency confusion / supply chain — unusual require() or import paths
9. ReDoS — catastrophic backtracking in regex patterns
10. Unsafe deserialization — JSON.parse of untrusted data without validation

For each finding:
[SEVERITY: CRITICAL/HIGH/MEDIUM/LOW] File:Line
Issue: Brief description
Risk: What an attacker could do
Fix: Remediation

End with exactly one of these lines:
SCAN_RESULT:CRITICAL (if any CRITICAL found)
SCAN_RESULT:HIGH (if highest is HIGH)
SCAN_RESULT:MEDIUM (if highest is MEDIUM)
SCAN_RESULT:LOW (if highest is LOW)
SCAN_RESULT:PASS (if no issues)
EOF
)"

SECURITY_OUTPUT=$("${CLAUDE_CMD[@]}" --print --dangerously-skip-permissions -p "${SECURITY_PROMPT}" 2>&1) || true
echo "${SECURITY_OUTPUT}" > "${SECURITY_REPORT}"

# ============== Skill 2: Quality & Config Leakage Review ==============
echo -e "${YELLOW}[2/2] Running code quality & config leakage scan...${NC}"

QUALITY_PROMPT="$(cat <<EOF
You are a senior TypeScript architect performing a pre-commit code quality and configuration review for a blockchain SDK project (TronWeb — a TRON blockchain JavaScript library).

## Staged Files:
${FILE_LIST}

## Staged Diff:
\`\`\`diff
${STAGED_DIFF}
\`\`\`

Review ONLY the staged changes above. Focus on:

Part 1 - Config & Secrets Leakage:
- Hardcoded RPC node URLs with embedded credentials
- Private keys, mnemonics, or API keys committed in source or test fixtures
- Sensitive values not using environment variables
- Debug/test credentials that could reach production
- Overly permissive CORS or missing origin checks in node server code

Part 2 - Code Quality:
- Unhandled promise rejections — missing await, missing .catch()
- Async/callback mixing that could cause silent failures
- Type safety regressions — use of any, unsafe casts, missing null checks
- Memory leaks — event listeners not removed, large buffers held in closures
- Missing input validation on public API methods (address, amount, hex string)
- Incorrect BigNumber / BN.js usage — floating point arithmetic for token amounts
- Error swallowing — try/catch that silences errors without logging
- Performance issues — unnecessary repeated RPC calls, unbounded arrays
- Breaking API changes without deprecation notice

For each finding:
[Category] [SEVERITY: CRITICAL/HIGH/MEDIUM/LOW] File:Line
Issue: Brief description
Suggestion: Remediation

Categories: CONFIG-LEAK | TYPE-SAFETY | ASYNC | ERROR-HANDLING | VALIDATION | CRYPTO | PERFORMANCE | API-DESIGN

End with exactly one of these lines:
SCAN_RESULT:CRITICAL (if any CRITICAL found)
SCAN_RESULT:HIGH (if highest is HIGH)
SCAN_RESULT:MEDIUM (if highest is MEDIUM)
SCAN_RESULT:LOW (if highest is LOW)
SCAN_RESULT:PASS (if no issues)
EOF
)"

QUALITY_OUTPUT=$("${CLAUDE_CMD[@]}" --print --dangerously-skip-permissions -p "${QUALITY_PROMPT}" 2>&1) || true
echo "${QUALITY_OUTPUT}" > "${QUALITY_REPORT}"

# ============== Result Analysis ==============
echo ""
echo -e "${CYAN}${BOLD}==================== Review Results ====================${NC}"

BLOCKED=false

# Parse security result
SEC_RESULT=$(echo "${SECURITY_OUTPUT}" | grep -oE 'SCAN_RESULT:(CRITICAL|HIGH|MEDIUM|LOW|PASS)' | tail -1 | cut -d: -f2 || echo "UNKNOWN")
case "${SEC_RESULT}" in
    CRITICAL)
        echo -e "${RED}${BOLD}[Security]  CRITICAL issues found${NC}"
        ${BLOCK_ON_CRITICAL} && BLOCKED=true
        ;;
    HIGH)
        echo -e "${RED}[Security]  HIGH severity issues found${NC}"
        ${BLOCK_ON_HIGH} && BLOCKED=true
        ;;
    MEDIUM)
        echo -e "${YELLOW}[Security]  MEDIUM severity issues found${NC}"
        ;;
    LOW)
        echo -e "${GREEN}[Security]  LOW severity issues only${NC}"
        ;;
    PASS)
        echo -e "${GREEN}[Security]  PASSED - no issues found${NC}"
        ;;
    *)
        echo -e "${YELLOW}[Security]  Could not determine result (review report manually)${NC}"
        ;;
esac

# Parse quality result
QUAL_RESULT=$(echo "${QUALITY_OUTPUT}" | grep -oE 'SCAN_RESULT:(CRITICAL|HIGH|MEDIUM|LOW|PASS)' | tail -1 | cut -d: -f2 || echo "UNKNOWN")
case "${QUAL_RESULT}" in
    CRITICAL)
        echo -e "${RED}${BOLD}[Quality]   CRITICAL issues found${NC}"
        ${BLOCK_ON_CRITICAL} && BLOCKED=true
        ;;
    HIGH)
        echo -e "${RED}[Quality]   HIGH severity issues found${NC}"
        ${BLOCK_ON_HIGH} && BLOCKED=true
        ;;
    MEDIUM)
        echo -e "${YELLOW}[Quality]   MEDIUM severity issues found${NC}"
        ;;
    LOW)
        echo -e "${GREEN}[Quality]   LOW severity issues only${NC}"
        ;;
    PASS)
        echo -e "${GREEN}[Quality]   PASSED - no issues found${NC}"
        ;;
    *)
        echo -e "${YELLOW}[Quality]   Could not determine result (review report manually)${NC}"
        ;;
esac

echo ""
echo -e "${CYAN}Reports saved to:${NC}"
echo -e "  Security: ${SECURITY_REPORT}"
echo -e "  Quality:  ${QUALITY_REPORT}"
echo ""

# ============== Blocking Decision ==============
if ${BLOCKED}; then
    echo -e "${RED}${BOLD}======================================================${NC}"
    echo -e "${RED}${BOLD}  COMMIT BLOCKED: CRITICAL/HIGH issues detected!${NC}"
    echo -e "${RED}${BOLD}======================================================${NC}"
    echo ""
    echo -e "${YELLOW}Please review the reports above and fix the issues before committing.${NC}"
    echo -e "${YELLOW}To bypass (NOT recommended): git commit --no-verify${NC}"
    echo ""
    exit 1
else
    echo -e "${GREEN}${BOLD}======================================================${NC}"
    echo -e "${GREEN}${BOLD}  COMMIT APPROVED: No blocking issues found.${NC}"
    echo -e "${GREEN}${BOLD}======================================================${NC}"
    echo ""
    exit 0
fi
