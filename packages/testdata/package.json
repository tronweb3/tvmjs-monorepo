{
  "name": "@tvmjs/testdata",
  "version": "1.0.0",
  "description": "Common test data for TVMJS packages.",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "import": {
        "typescript": "./src/index.ts",
        "default": "./dist/esm/index.js"
      },
      "require": "./dist/cjs/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "../../config/cli/ts-build.sh",
    "clean": "../../config/cli/clean-package.sh",
    "lint": "npm run biome && eslint --config ./eslint.config.mjs .",
    "lint:fix": "npm run biome:fix && eslint --fix --config ./eslint.config.mjs .",
    "tsc": "../../config/cli/ts-compile.sh"
  },
  "devDependencies": {
    "@tvmjs/block": "1.0.0",
    "@tvmjs/util": "1.0.0"
  },
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tronweb3/tvmjs-monorepo.git"
  },
  "homepage": "https://github.com/tronweb3/tvmjs-monorepo/tree/master/packages/testdata#readme",
  "bugs": {
    "url": "https://github.com/tronweb3/tvmjs-monorepo/issues?q=is%3Aissue+label%3A%22package%3A+testdata%22"
  },
  "contributors": ["TVMJS Team"],
  "keywords": ["tron", "tvm"]
}
